{
  "manifest_version": 3,
  "name": "TrustScore Extension",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background/background.js"
  },
  "host_permissions": [
    "https://*.myntra.com/*",
    "https://*.flipkart.com/*",
    "https://trustscore-ml-model.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.myntra.com/*",
        "https://*.flipkart.com/*"
      ],
      "js": ["content/content.js"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}